{
  "name": "playwright_framework_js",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "clean:allure": "rimraf reports/allure-results reports/allure-report reports/cucumber-report.html reports/videos reports/screenshots reports/logs",

    "test:chromium": "cross-env BROWSER=chromium cucumber-js",
    "test:firefox": "cross-env BROWSER=firefox cucumber-js",
    "test:webkit": "cross-env BROWSER=webkit cucumber-js",

    "test:chromium:headed": "cross-env BROWSER=chromium HEADLESS=false cucumber-js",
    "test:firefox:headed": "cross-env BROWSER=firefox HEADLESS=false cucumber-js",
    "test:webkit:headed": "cross-env BROWSER=webkit HEADLESS=false cucumber-js",

    "testAll:parallel": "npm-run-all clean:allure --parallel test:chromium test:firefox test:webkit",
    "testAll:parallel:headed": "npm-run-all clean:allure --parallel test:chromium test:firefox test:webkit:headed",

    "allure:generate": "allure generate reports/allure-results --clean -o reports/allure-report",
    "allure:open": "allure open reports/allure-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.5",
    "allure-cucumberjs": "^3.6.0",
    "cross-env": "^10.1.0",
    "dotenv": "^16.6.1",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.3",
    "winston": "^3.17.0"
  },
  "dependencies": {
    "allure-js-commons": "^3.6.0"
  }
}
